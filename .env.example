# ASR provider selection
ASR_PROVIDER=local
ASR_LANGUAGE_CODE=zh-CN

# Google Speech-to-Text
GOOGLE_STT_MODEL=latest_long

# Groq Whisper ASR
GROQ_ASR_MODEL=whisper-large-v3
GROQ_API_KEY=

# Local ASR (faster-whisper)
ASR_MODEL=large-v3
ASR_DEVICE=auto
ASR_COMPUTE_TYPE=float16

# LLM provider selection
LLM_PROVIDER=openrouter

# Ollama (local adapter)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=30

# LM Studio (OpenAI-compatible local server)
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=local-model

# OpenAI
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Free models with good Chinese + JSON support:
#   qwen/qwen3-coder:free               (recommended — excellent structured output)
#   deepseek/deepseek-chat-v3-0324:free  (strong Chinese, fast)
#   google/gemma-3-27b-it:free           (good general, weaker Chinese)
OPENROUTER_MODEL=qwen/qwen3-coder:free
OPENROUTER_API_KEY=

# App endpoints
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://127.0.0.1:5173
VOICE_MAP_DATA_DIR=data
